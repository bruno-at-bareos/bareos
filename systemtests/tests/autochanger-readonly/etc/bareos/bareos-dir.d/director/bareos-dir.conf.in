Director {                            # define myself
  Name = bareos-dir
  QueryFile = "@scriptdir@/query.sql"
  Maximum Concurrent Jobs = 100
  Password = "@dir_password@"         # Console password
  Messages = Daemon
  Auditing = yes
  Working Directory =  "@working_dir@"
  DirPort = @dir_port@
  Heartbeat Interval = 15
  TLS Require = No
  TLS Enable = No
}
